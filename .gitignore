# Python cache
__pycache__/
**/__pycache__/
*.py[cod]
*$py.class

# Virtual environment
.venv/
venv/
env/

# Distribution / build
build/
dist/
*.egg-info/

# Jupyter
.ipynb_checkpoints/

# Test / coverage
.pytest_cache/
.coverage
htmlcov/

# IDE / editor
.vscode/
.idea/

# OS files
.DS_Store
Thumbs.db

# Local environment variables
.env

# Generated logs / temp / cache
*.log
logs/
tmp/
temp/
cache/

# Raw downloaded geospatial data can be large or unstable
data/raw/

# Local planning/spec/prompt files
SPEC*.md
PROMPT*.md
NOTES*.md
notes/
local_notes/

# LaTeX generated/source snippets from simulation repo
*.aux
*.bbl
*.bcf
*.blg
*.fdb_latexmk
*.fls
*.lof
*.lot
*.out
*.run.xml
*.synctex.gz
*.toc
*.xdv
*.nav
*.snm
*.vrb
*.tex

# Keep reproducible processed data and report-level outputs
!data/processed/
!data/processed/*.csv

!outputs/tables/
!outputs/tables/*.csv

!outputs/figures/
!outputs/figures/*.png