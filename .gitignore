# Python cache
__pycache__/
**/__pycache__/
*.py[cod]
*$py.class

# Virtual environment
.venv/
venv/
env/

# Distribution / build
build/
dist/
*.egg-info/

# Jupyter
.ipynb_checkpoints/

# Test / coverage
.pytest_cache/
.coverage
htmlcov/

# IDE / editor
.vscode/
.idea/

# OS files
.DS_Store
Thumbs.db

# Local environment variables
.env

# Generated logs
*.log
logs/
tmp/
temp/
cache/
data/raw/

# LaTeX auxiliary files
*.aux
*.bbl
*.bcf
*.blg
*.fdb_latexmk
*.fls
*.lof
*.lot
*.out
*.run.xml
*.synctex.gz
*.toc
*.xdv
*.nav
*.snm
*.vrb

# Keep source LaTeX files tracked
!*.tex

# Keep reproducible processed data and report outputs tracked
!data/processed/
!data/processed/*.csv
!outputs/tables/
!outputs/tables/*.csv
!outputs/tables/*.tex
!outputs/figures/
!outputs/figures/*.png
